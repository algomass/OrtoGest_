<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ortogest.ortogestapp.graphiccontroller.MagazzinoGraphicController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Gestione Magazzino" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#logoutAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Esci / Cambia Utente" />
            </children>
            <padding><Insets left="20.0" right="20.0" /></padding>
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0" style="-fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
            <children>
                <HBox spacing="15.0">
                    <children>
                        <TextField fx:id="searchField" onKeyReleased="#cercaProdottoAction" prefHeight="35.0" prefWidth="300.0" promptText="Cerca prodotto nell'inventario..." />
                        <Button onAction="#cercaProdottoAction" prefHeight="35.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Cerca" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#apriSegnalazioneAnomaliaAction" prefHeight="35.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Segnala Anomalia">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Button>
                        <Button onAction="#registraLottoAction" prefHeight="35.0" style="-fx-background-color: #e67e22; -fx-text-fill: white;" text="+ Registra Nuovo Lotto">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>

                <TableView fx:id="inventarioTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" prefWidth="300.0" text="Prodotto" />
                        <TableColumn fx:id="colPrezzo" prefWidth="200.0" text="Prezzo (€/Kg)" />
                        <TableColumn fx:id="colGiacenza" prefWidth="250.0" text="Giacenza Attuale (Kg)" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>
