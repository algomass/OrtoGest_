<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ortogest.ortogestapp.graphiccontroller.ClienteGraphicController">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Area Personale Cliente" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                
                <!-- SEZIONE CARRELLO NELL'HEADER -->
                <HBox alignment="CENTER" spacing="15.0" style="-fx-padding: 0 20 0 0;">
                    <children>
                        <Label fx:id="cartSummaryLabel" text="Carrello Vuoto" textFill="#ecf0f1">
                            <font><Font size="14.0" /></font>
                        </Label>
                        <Button fx:id="btnConfermaOrdine" onAction="#confermaOrdineAction" 
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" 
                                text="CONFERMA ORDINE" visible="false" />
                        <Button fx:id="btnSvuotaCarrello" onAction="#svuotaCarrelloAction" 
                                style="-fx-background-color: transparent; -fx-border-color: #bdc3c7; -fx-border-radius: 3; -fx-text-fill: #bdc3c7;" 
                                text="Svuota Carrello" visible="false" />
                    </children>
                </HBox>

                <Button onAction="#logoutAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Esci / Cambia Utente" />
            </children>
            <padding><Insets left="20.0" right="20.0" /></padding>
        </HBox>
    </top>

    <!-- SIDEBAR SINISTRA -->
    <left>
        <VBox prefWidth="180.0" spacing="0.0" style="-fx-background-color: #34495e;">
            <padding><Insets top="15.0" /></padding>
            <children>
                <!-- Titolo sidebar -->
                <Label text="CATEGORIE" textFill="#95a5a6" style="-fx-padding: 10 20 10 20;">
                    <font><Font name="System Bold" size="11.0" /></font>
                </Label>

                <Button fx:id="btnFrutta" onAction="#mostraFruttaAction" text="Frutta" prefWidth="180.0" prefHeight="45.0"
                        style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-size: 14; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20; -fx-cursor: hand;" />

                <Button fx:id="btnVerdura" onAction="#mostraVerduraAction" text="Verdura" prefWidth="180.0" prefHeight="45.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-font-size: 14; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20; -fx-cursor: hand;" />

                <!-- Separatore visivo -->
                <Region prefHeight="20.0" />
                <Label text="ACCOUNT" textFill="#95a5a6" style="-fx-padding: 10 20 10 20;">
                    <font><Font name="System Bold" size="11.0" /></font>
                </Label>

                <Button fx:id="btnOrdini" onAction="#mostraOrdiniAction" text="I Miei Ordini" prefWidth="180.0" prefHeight="45.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-font-size: 14; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 20; -fx-cursor: hand;" />
            </children>
        </VBox>
    </left>

    <!-- AREA CENTRALE: StackPane per alternare tra card e tabella ordini -->
    <center>
        <VBox style="-fx-background-color: #ecf0f1;">
            <children>
                <!-- Titolo della sezione corrente -->
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #ecf0f1; -fx-padding: 20 25 10 25;">
                    <children>
                        <Label fx:id="titoloSezione" text="Catalogo — Frutta" textFill="#2c3e50">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="searchField" onKeyReleased="#cercaProdottoAction" prefWidth="250.0" promptText="Cerca prodotto..." />
                    </children>
                </HBox>

                <StackPane VBox.vgrow="ALWAYS">
                    <!-- Vista Card Prodotti (dentro ScrollPane) -->
                    <ScrollPane fx:id="scrollPaneCatalogo" fitToWidth="true" style="-fx-background: #ecf0f1; -fx-background-color: #ecf0f1;">
                        <content>
                            <FlowPane fx:id="flowPaneProdotti" hgap="20.0" vgap="20.0" style="-fx-padding: 15 25 25 25;" />
                        </content>
                    </ScrollPane>

                    <!-- Vista Tabella Ordini (nascosta di default) -->
                    <VBox fx:id="ordiniContainer" visible="false" style="-fx-background-color: #ecf0f1; -fx-padding: 15 25 25 25;">
                        <children>
                            <TableView fx:id="ordiniTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn resizable="false" prefWidth="100.0" text="ID Ordine">
                                        <cellValueFactory><PropertyValueFactory property="idOrdine" /></cellValueFactory>
                                    </TableColumn>
                                    <TableColumn resizable="false" prefWidth="350.0" text="Riepilogo Prodotti">
                                        <cellValueFactory><PropertyValueFactory property="riepilogoProdotti" /></cellValueFactory>
                                    </TableColumn>
                                    <TableColumn resizable="false" prefWidth="100.0" text="Totale (€)">
                                        <cellValueFactory><PropertyValueFactory property="totale" /></cellValueFactory>
                                    </TableColumn>
                                    <TableColumn resizable="false" prefWidth="120.0" text="Stato">
                                        <cellValueFactory><PropertyValueFactory property="stato" /></cellValueFactory>
                                    </TableColumn>
                                </columns>
                            </TableView>
                            
                            <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 15 0 0 0;">
                                <children>
                                    <Button text="Rimuovi Ordine Selezionato" onAction="#rimuoviOrdineAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </StackPane>

                <!-- Barra messaggi in basso -->
                <HBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 10 25 10 25;">
                    <children>
                        <Label fx:id="errorLabel" textFill="#e74c3c" visible="false">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Label>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
