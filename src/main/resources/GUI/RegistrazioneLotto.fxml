<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ortogest.ortogestapp.graphiccontroller.RegistrazioneLottoGraphicController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Button onAction="#indietroAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Indietro" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Registra Nuovo Lotto" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="100.0" right="100.0" top="40.0" />
            </padding>
            <children>
                <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>
                        <Label text="Dati Documento di Trasporto / Bancale" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="20.0" />
                            </VBox.margin>
                        </Label>

                        <GridPane hgap="20.0" vgap="15.0">
                            <children>
                                <Label text="ID Lotto (da Bancale):" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <TextField fx:id="idLottoField" promptText="Es. LOT-2026-001" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300.0"/>

                                <Label text="Nome Fornitore:" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <TextField fx:id="fornitoreField" promptText="Es. Ortofrutta Spa" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Tipologia Prodotto:" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <TextField fx:id="prodottoField" prefWidth="300.0" promptText="Inserisci tipologia prodotto" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Quantità Ricevuta (Kg):" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <TextField fx:id="quantitaField" promptText="Es. 50.5" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Data di Arrivo:" GridPane.columnIndex="0" GridPane.rowIndex="4">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <DatePicker fx:id="dataArrivoPicker" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <Label text="Data di Scadenza:" GridPane.columnIndex="0" GridPane.rowIndex="5">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <DatePicker fx:id="dataScadenzaPicker" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                <Label text="Costo d'Acquisto (€):" GridPane.columnIndex="0" GridPane.rowIndex="6">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <TextField fx:id="costoAcquistoField" promptText="Es. 120.50 (Opzionale)" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                            </children>
                        </GridPane>
                        
                        <Label fx:id="errorLabel" textFill="#e74c3c" visible="false" wrapText="true">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="15.0" />
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="20.0">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                    <children>
                        <Button onAction="#segnalaAnomaliaAction" prefHeight="40.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Segnala Anomalia (Merce Danneggiata/Mancante)">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#salvaLottoAction" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Salva Lotto">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
