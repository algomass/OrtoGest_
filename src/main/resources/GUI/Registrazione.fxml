<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ortogest.ortogestapp.graphiccontroller.RegistrazioneGraphicController">
    <children>
        <VBox alignment="CENTER" maxWidth="400.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label text="OrtoGest" textFill="#27ae60">
                    <font><Font name="System Bold" size="36.0" /></font>
                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                </Label>

                <Label text="Registrazione Nuovo Cliente" textFill="#7f8c8d">
                    <font><Font size="14.0" /></font>
                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                </Label>

                <Label fx:id="messageLabel" textFill="#e74c3c" visible="false">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>

                <TextField fx:id="nomeField" prefHeight="40.0" promptText="Nome completo" />
                <TextField fx:id="emailField" prefHeight="40.0" promptText="Email" />
                <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Password" />
                <PasswordField fx:id="confermaPasswordField" prefHeight="40.0" promptText="Conferma Password" />

                <Button onAction="#registraAction" prefHeight="45.0" prefWidth="360.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="REGISTRATI">
                    <font><Font name="System Bold" size="16.0" /></font>
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Button>
                
                <Label onMouseClicked="#tornaAlLoginAction" text="Sei già registrato? Torna al Login" textFill="#3498db" underline="true">
                    <font><Font size="12.0" /></font>
                    <cursor><javafx.scene.Cursor fx:constant="HAND" /></cursor>
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Label>
            </children>
            <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
        </VBox>
    </children>
</VBox>
