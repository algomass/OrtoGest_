<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ortogest.ortogestapp.graphiccontroller.CassaGraphicController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Cassa" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#logoutAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Esci / Cambia Utente" />
            </children>
            <padding><Insets left="20.0" right="20.0" /></padding>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.65" prefHeight="160.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <items>
                <VBox spacing="15.0" style="-fx-background-color: white;">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <HBox spacing="10.0">
                            <children>
                                <TextField prefHeight="40.0" promptText="Codice a barre o nome prodotto..." HBox.hgrow="ALWAYS" />
                                <Button prefHeight="40.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Aggiungi" />
                            </children>
                        </HBox>
                        <TableView VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="200.0" text="Prodotto" />
                                <TableColumn prefWidth="75.0" text="Q.tà (Kg)" />
                                <TableColumn prefWidth="100.0" text="Prezzo Un." />
                                <TableColumn prefWidth="100.0" text="Subtotale" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #ecf0f1;">
                    <padding><Insets bottom="30.0" left="20.0" right="20.0" top="40.0" /></padding>
                    <children>
                        <Label text="TOTALE DA PAGARE" textFill="#7f8c8d">
                            <font><Font size="18.0" /></font>
                        </Label>
                        <Label text="€ 0,00" textFill="#27ae60">
                            <font><Font name="System Bold" size="48.0" /></font>
                        </Label>

                        <Region VBox.vgrow="ALWAYS" />

                        <VBox alignment="CENTER_LEFT" prefHeight="113.0" prefWidth="240.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <children>
                                <Label text="Metodo di Pagamento:" textFill="#2c3e50">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <RadioButton mnemonicParsing="false" selected="true" text="Contanti">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="metodoPagamentoGroup" />
                                    </toggleGroup>
                                    <font><Font size="14.0" /></font>
                                </RadioButton>
                                <RadioButton mnemonicParsing="false" text="Carta di Credito / POS" toggleGroup="$metodoPagamentoGroup">
                                    <font><Font size="14.0" /></font>
                                </RadioButton>
                            </children>
                        </VBox>

                        <Button prefHeight="60.0" prefWidth="269.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="EMETTI SCONTRINO">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                        <Button prefHeight="40.0" prefWidth="271.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="Annulla Operazione" />
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
