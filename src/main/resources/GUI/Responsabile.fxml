<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ortogest.ortogestapp.graphiccontroller.ResponsabileGraphicController">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Area Responsabile - Gestione Catalogo e Lotti" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#apriGestioneOrdiniAction" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Gestione Ordini Online">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button fx:id="btnToggleVista" onAction="#toggleVistaAction" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Prodotti da scontare">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button fx:id="btnDaPrezzare" onAction="#vistaDaPrezzareAction" style="-fx-background-color: #9b59b6; -fx-text-fill: white;" text="Prodotti da prezzare">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button onAction="#logoutAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Esci / Cambia Utente" />
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
            <children>

                <VBox fx:id="sezioneSuperiore" spacing="15.0" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <Label text="Elenco Prodotti a Sistema">
                                <font>
                                    <Font name="System Bold" size="16.0" />
                                </font>
                            </Label>
                            <Region HBox.hgrow="ALWAYS" />
                            <CheckBox fx:id="chkMostraStorico" onAction="#aggiornaTabelleAction" text="Mostra Storico (Inclusi Esauriti/Scaduti)" />
                        </HBox>

                        <!-- Tabella Prodotti -->
                        <TableView fx:id="tabellaProdotti" prefHeight="150.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNome" prefWidth="250.0" text="Nome Prodotto">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="nome" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn fx:id="colCategoria" prefWidth="150.0" text="Categoria">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="categoria" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn fx:id="colGiacenza" prefWidth="150.0" text="Giacenza Tot. (Kg)">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="giacenza" />
                                    </cellValueFactory>
                                </TableColumn>
                            </columns>
                        </TableView>
                        
                        <!-- Modifica Categoria Prodotto -->
                        <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5;">
                            <Label text="Prodotto Selezionato:" />
                            <TextField fx:id="prodottoSelezionatoField" editable="false" prefWidth="150.0" promptText="Nessun prodotto" style="-fx-background-color: #f1f2f6;" />
                            
                            <Label text="Modifica Categoria:" />
                            <ComboBox fx:id="nuovaCategoriaComboBox" prefWidth="120.0" promptText="Categoria" />
                            <Button onAction="#aggiornaCategoriaAction" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Salva Categoria" />
                        </HBox>
                    </children>
                </VBox>

                <Label text="Lotti del Prodotto Selezionato">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <!-- Tabella Lotti -->
                <TableView fx:id="tabellaLotti" prefHeight="150.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdLotto" prefWidth="90.0" text="ID Lotto">
                            <cellValueFactory>
                                <PropertyValueFactory property="idLotto" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colNomeProdottoLotto" prefWidth="150.0" text="Prodotto">
                            <cellValueFactory>
                                <PropertyValueFactory property="nomeProdotto" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colDataScadenza" prefWidth="90.0" text="Scadenza">
                            <cellValueFactory>
                                <PropertyValueFactory property="dataScadenza" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colQuantitaLotto" prefWidth="100.0" text="Qtà (Kg)">
                            <cellValueFactory>
                                <PropertyValueFactory property="quantitaKg" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colCostoAcquisto" prefWidth="100.0" text="Costo (€)">
                            <cellValueFactory>
                                <PropertyValueFactory property="costoAcquisto" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colPrezzoVendita" prefWidth="100.0" text="Prezzo Vend. (€)">
                            <cellValueFactory>
                                <PropertyValueFactory property="prezzoVendita" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colScontoAttivo" prefWidth="80.0" text="In Sconto">
                            <cellValueFactory>
                                <PropertyValueFactory property="scontoScadenzaAttivo" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colPrezzoScontato" prefWidth="120.0" text="Prezzo Scontato (€)">
                            <cellValueFactory>
                                <PropertyValueFactory property="prezzoScontato" />
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>

                <!-- Modifica Prezzo Lotto -->
                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="Imposta Prezzi per il Lotto Selezionato">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Label>
                    
                    <HBox alignment="CENTER" spacing="15.0">
                        <Label text="ID Lotto:" />
                        <TextField fx:id="lottoSelezionatoField" editable="false" prefWidth="100.0" promptText="ID" style="-fx-background-color: #f1f2f6;" />
                        
                        <Label text="Prezzo Base (€):" />
                        <TextField fx:id="prezzoVenditaField" prefWidth="70.0" promptText="Es. 2.50" />
                        
                        <CheckBox fx:id="scontoCheckBox" text="Attiva Sconto Scadenza" />
                        
                        <Label text="Prezzo Scontato (€):" />
                        <TextField fx:id="prezzoScontatoField" prefWidth="70.0" promptText="Es. 1.50" />
                        
                        <Button onAction="#aggiornaPrezzoLottoAction" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Salva Prezzi">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                    </HBox>
                    
                    <Label fx:id="messaggioLabel" textFill="#e74c3c" visible="false">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Label>
                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>
