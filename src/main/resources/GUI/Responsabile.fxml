<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ortogest.ortogestapp.graphiccontroller.ResponsabileGraphicController">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #8e44ad;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Area Responsabile - Gestione Catalogo" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#logoutAction" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Logout">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
            </padding>
            <children>

                <Label text="Elenco Prodotti a Sistema">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Tabella Prodotti -->
                <TableView fx:id="tabellaProdotti" prefHeight="300.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" prefWidth="250.0" text="Nome Prodotto">
                            <cellValueFactory>
                                <PropertyValueFactory property="nome" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colCategoria" prefWidth="150.0" text="Categoria">
                            <cellValueFactory>
                                <PropertyValueFactory property="categoria" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colGiacenza" prefWidth="150.0" text="Giacenza (Kg)">
                            <cellValueFactory>
                                <PropertyValueFactory property="giacenza" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colPrezzoAcquisto" prefWidth="150.0" text="Prezzo Acquisto Medio (€)">
                            <cellValueFactory>
                                <PropertyValueFactory property="prezzoAcquistoMedio" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colPrezzo" prefWidth="150.0" text="Prezzo al Pubblico (€)">
                            <cellValueFactory>
                                <PropertyValueFactory property="prezzoAttuale" />
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>

                <!-- Modifica Prezzo -->
                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 5;">
                    <Label text="Imposta Prezzo di Vendita">
                        <font>
                            <Font name="System Bold" size="16.0" />
                        </font>
                    </Label>
                    
                    <HBox alignment="CENTER" spacing="15.0">
                        <Label text="Prodotto Selezionato:" />
                        <TextField fx:id="prodottoSelezionatoField" editable="false" prefWidth="200.0" promptText="Nessun prodotto selezionato" style="-fx-background-color: #f1f2f6;" />
                        
                        <Label text="Nuova Categoria:" />
                        <ComboBox fx:id="nuovaCategoriaComboBox" prefWidth="120.0" promptText="Categoria" />

                        <Label text="Nuovo Prezzo (€):" />
                        <TextField fx:id="nuovoPrezzoField" prefWidth="80.0" promptText="Es. 2.50" />
                        
                        <Button onAction="#aggiornaPrezzoAction" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Salva Prezzo">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </HBox>
                    
                    <Label fx:id="messaggioLabel" textFill="#e74c3c" visible="false">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Label>
                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>
