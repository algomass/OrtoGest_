<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.ortogest.ortogestapp.graphiccontroller.GestioneOrdiniOnlineGraphicController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Gestione Ordini Online (Clicca &amp; Ritira)" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#logoutAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Esci / Cambia Utente" />
            </children>
            <padding><Insets left="20.0" right="20.0" /></padding>
        </HBox>
    </top>

    <center>
        <HBox spacing="20.0" style="-fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
            <children>

                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <TextField prefHeight="35.0" prefWidth="200.0" promptText="Cerca N° Ordine o Cliente..." />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="Filtra:" textFill="#7f8c8d" />
                                <ComboBox prefHeight="35.0" prefWidth="180.0" promptText="Tutti gli stati" style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 3;" />
                            </children>
                        </HBox>

                        <TableView fx:id="ordiniTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colIdOrdine" prefWidth="90.0" text="N° Ordine" />
                                <TableColumn fx:id="colCliente" prefWidth="121.5999755859375" text="Cliente" />
                                <TableColumn fx:id="colOrario" prefWidth="88.800048828125" text="Orario Ritiro" />
                                <TableColumn fx:id="colTotale" prefWidth="127.199951171875" text="Totale €" />
                                <TableColumn fx:id="colStato" prefWidth="123.20001220703125" text="Stato Attuale" />
                            </columns>
                        </TableView>

                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="586.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                            <children>
                                <Label prefHeight="18.0" prefWidth="103.0" text="Legenda Stati:">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <HBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Circle fill="#e74c3c" radius="6.0" />
                                        <Label text="Da Completare" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Circle fill="#f39c12" radius="6.0" />
                                        <Label text="Pronto per Ritiro" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Circle fill="#27ae60" radius="6.0" />
                                        <Label text="Ritirato (Concluso)" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label text="Dettaglio Ordine" textFill="#16a085">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <Separator prefWidth="200.0" />

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Cliente:" textFill="#7f8c8d" />
                                <Label fx:id="dettaglioClienteLabel" text="Seleziona un ordine...">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <Label fx:id="dettaglioOrarioLabel" text="" textFill="#e74c3c">
                                    <font><Font name="System Italic" size="12.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="Da inserire nel sacchetto:" textFill="#7f8c8d" />
                                <ListView fx:id="dettaglioProdottiList" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <Label fx:id="messaggioLabel" textFill="#e74c3c">
                            <VBox.margin><Insets top="5.0" /></VBox.margin>
                        </Label>
                        <Label text="Aggiorna Stato:" textFill="#7f8c8d">
                            <VBox.margin><Insets top="10.0" /></VBox.margin>
                        </Label>
                        <Button fx:id="btnSegnaPronto" onAction="#segnaComeProntoAction" prefHeight="45.0" prefWidth="260.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="📦 SEGNA COME PRONTO">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                    </children>
                </VBox>

            </children>
        </HBox>
    </center>
</BorderPane>
